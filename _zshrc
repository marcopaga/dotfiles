# === Bootstrap oh-my-zsh (runs only if not already installed) ===
if [ ! -d "$HOME/.oh-my-zsh" ]; then
  echo "Oh my zsh is not installed. Please install it: Info at: https://ohmyz.sh/"
  return 1
fi

# Path to your oh-my-zsh installation.
export ZSH="$HOME/.oh-my-zsh"

# Theme
# See https://github.com/ohmyzsh/ohmyzsh/wiki/Themes
ZSH_THEME="robbyrussell"

# Plugins
# Standard plugins: $ZSH/plugins/  Custom plugins: $ZSH_CUSTOM/plugins/
# Add wisely — too many plugins slow down shell startup.
plugins=(git kubectl kubectx dotenv nvm asdf extract colored-man-pages)

source $ZSH/oh-my-zsh.sh

# === zsh plugins (installed via Homebrew) ===
# zsh-autosuggestions: fish-style inline history suggestions (→ or Tab to accept)
[ -f /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh ] && \
  source /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh
# zsh-syntax-highlighting: real-time command syntax coloring (must be sourced last)
[ -f /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ] && \
  source /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

# === Editor ===
export EDITOR="vim"
export VISUAL="vim"

# === PATH ===
export PATH="/opt/homebrew/bin:$PATH"
export PATH="/Users/marco/.rd/bin:$PATH"     ### MANAGED BY RANCHER DESKTOP (DO NOT EDIT)
export PATH="${ASDF_DATA_DIR:-$HOME/.asdf}/shims:$PATH"
export PATH="$HOME/.local/bin:$PATH"
export PATH="/Users/marco/.opencode/bin:$PATH"
# Homebrew Ruby gems (e.g. tmuxinator)
# /opt/homebrew/opt/ruby is the stable unversioned symlink maintained by Homebrew.
export PATH="/opt/homebrew/opt/ruby/bin:$PATH"
# Gem executables live under the versioned gems dir; use a glob to avoid hardcoding the version.
for _gem_bin in /opt/homebrew/lib/ruby/gems/*/bin; do
  export PATH="$_gem_bin:$PATH"
done
unset _gem_bin

# === NVM ===
export NVM_DIR="$HOME/.nvm"
[ -s "/opt/homebrew/opt/nvm/nvm.sh" ] && \. "/opt/homebrew/opt/nvm/nvm.sh"
[ -s "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm" ] && \. "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm"

# Auto-switch node version when entering a directory with an .nvmrc
autoload -U add-zsh-hook
load-nvmrc() {
  local node_version="$(nvm version)"
  local nvmrc_path="$(nvm_find_nvmrc)"

  if [ -n "$nvmrc_path" ]; then
    local nvmrc_node_version=$(nvm version "$(cat "${nvmrc_path}")")

    if [ "$nvmrc_node_version" = "N/A" ]; then
      nvm install
    elif [ "$nvmrc_node_version" != "$node_version" ]; then
      nvm use
    fi
  elif [ "$node_version" != "$(nvm version default)" ]; then
    echo "Reverting to nvm default version"
    nvm use default
  fi
}
add-zsh-hook chpwd load-nvmrc
load-nvmrc

# === AsyncAPI CLI Autocomplete ===
ASYNCAPI_AC_ZSH_SETUP_PATH=/Users/marco/Library/Caches/@asyncapi/cli/autocomplete/zsh_setup
test -f $ASYNCAPI_AC_ZSH_SETUP_PATH && source $ASYNCAPI_AC_ZSH_SETUP_PATH

# === tmux aliases ===
alias ta='tmux attach'
alias tl='tmux ls'
alias t='tmux attach || tmux'

# === tmuxinator ===
# Shell completion — glob avoids hardcoding the gem version in the path.
for _mux_comp in /opt/homebrew/lib/ruby/gems/*/gems/tmuxinator-*/completion/tmuxinator.zsh; do
  [ -f "$_mux_comp" ] && source "$_mux_comp"
done
unset _mux_comp
# Convenient short aliases
alias mux='tmuxinator'
alias muxs='tmuxinator start'
alias muxo='tmuxinator open'
alias muxl='tmuxinator list'

# === eza (replaces ls) ===
alias ls='eza --icons'
alias ll='eza -la --icons --git'
alias lt='eza --tree --icons'

# === zoxide (replaces autojump) ===
eval "$(zoxide init zsh)"

# === SAFEHOUSE CONFIG https://agent-safehouse.dev/ ===
safe() { safehouse --add-dirs-ro=~/Projects --enable=docker,kubectl "$@"; }
claude()   { safe claude --dangerously-skip-permissions "$@"; }
codex()    { safe codex --dangerously-bypass-approvals-and-sandbox "$@"; }
amp()      { safe amp --dangerously-allow-all "$@"; }
gemini()   { NO_BROWSER=true safe gemini --yolo "$@"; }
opencode() { OPENCODE_PERMISSION='{"*":"allow"}' safe opencode "$@"; }
